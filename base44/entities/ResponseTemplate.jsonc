      "description": "\u0627\u0644\u0645\u062f\u0629 \u0627\u0644\u0645\u0642\u062f\u0631\u0629 \u0644\u0644\u062a\u0646\u0641\u064a\u0630 \u0628\u0627\u0644\u0623\u064a\u0627\u0645"
