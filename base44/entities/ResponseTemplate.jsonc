      "description": "\u0627\u0644\u0642\u0633\u0645 \u0627\u0644\u0645\u0646\u0627\u0633\u0628"
    },
    "severity": {
      "type": "string",
      "enum": [
        "\u062d\u0631\u062c\u0629",
        "\u0639\u0627\u0644\u064a\u0629",
        "\u0645\u062a\u0648\u0633\u0637\u0629",
        "\u0645\u0646\u062e\u0641\u0636\u0629",
        "\u0627\u0644\u0643\u0644"
      ],
      "default": "\u0627\u0644\u0643\u0644",
      "description": "\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u062e\u0637\u0648\u0631\u0629 \u0627\u0644\u0645\u0646\u0627\u0633\u0628"
    },
    "response_text": {
      "type": "string",
      "description": "\u0646\u0635 \u0627\u0644\u0631\u062f \u0627\u0644\u062c\u0627\u0647\u0632"
    },
